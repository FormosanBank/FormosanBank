<?xml version="1.0" encoding="utf-8"?>
<!--
  C022 fixture (revised 2026-05-31): '*' ungrammaticality marker can
  appear at ANY position in a FORM (sentence-initial, mid-sentence, or
  sentence-final). The cleaner must emit a c022 warning per occurrence
  AND preserve the FORM text unchanged (no removal). S_4 is a control
  with no '*' — no warning for its id.

  The pre-revision framing pinned only the sentence-initial case;
  user direction (2026-05-30) broadens the rule to any position.
-->
<TEXT id="TEST_C022" citation="test" BibTeX_citation="@test{test}"
      copyright="test" xml:lang="ami">
  <S id="S_1">
    <FORM kindOf="original">*Mu ka patas nii.</FORM>
    <FORM kindOf="standard">*Mu ka patas nii.</FORM>
  </S>
  <S id="S_2">
    <FORM kindOf="original">Mu ka *patas nii.</FORM>
    <FORM kindOf="standard">Mu ka *patas nii.</FORM>
  </S>
  <S id="S_3">
    <FORM kindOf="original">Mu ka patas nii*.</FORM>
    <FORM kindOf="standard">Mu ka patas nii*.</FORM>
  </S>
  <S id="S_4">
    <FORM kindOf="original">Mu ka patas nii.</FORM>
    <FORM kindOf="standard">Mu ka patas nii.</FORM>
  </S>
</TEXT>
