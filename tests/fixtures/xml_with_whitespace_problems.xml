<?xml version="1.0" encoding="utf-8"?>
<!--
  Negative fixture for the clean_xml whitespace-normalization behavior.

  Shape: one S with both FORM tiers containing repeated spaces, leading
  and trailing whitespace, and a triple-space run between two words.

  Exercises: clean_xml.py must collapse runs of internal whitespace to
  single spaces and trim leading/trailing whitespace in FORM text. The
  "triple space" pattern is the marker tested — if a cleanup pass
  collapses doubles but not triples (or vice versa), this catches it.
-->
<TEXT id="TEST_WS" citation="test" BibTeX_citation="@test{test}" copyright="test" xml:lang="ami" dialect="unknown">
  <S id="S_1">
    <FORM kindOf="original">  Halo,   hapinangha.   </FORM>
    <FORM kindOf="standard">  Halo,   hapinangha.   </FORM>
  </S>
</TEXT>
