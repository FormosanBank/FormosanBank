<?xml version="1.0" encoding="utf-8"?>
<!--
  Negative fixture for the clean_xml HTML-entity resolution behavior.

  Shape: one S with both FORM tiers containing a mix of HTML entity
  escapes: &amp; (ampersand), &quot; (double-quote), &#39; (apostrophe
  written as a numeric character reference).

  Exercises: clean_xml.py must resolve these entities to their literal
  forms during cleaning. The most insidious regression class is double-
  encoding (e.g., &amp; becomes &amp;amp; on a second pass) — the
  idempotency test catches that explicitly.
-->
<TEXT id="TEST_HE" citation="test" BibTeX_citation="@test{test}" copyright="test" xml:lang="ami">
  <S id="S_1">
    <FORM kindOf="original">Tom &amp; Jerry &quot;cartoon&quot; episode &#39;1</FORM>
    <FORM kindOf="standard">Tom &amp; Jerry &quot;cartoon&quot; episode &#39;1</FORM>
  </S>
</TEXT>
