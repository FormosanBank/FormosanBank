<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_kiukay_ma01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: kiukay_ma01 1 min.eaf; anonymized speaker label: ma01" audio="kiukay_ma01.wav" dialect="Southern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_kiukay_ma01_S1">
        <FORM>a tja kai tja senay,</FORM>
        <AUDIO start="50.13" end="53.58"/>
    </S>
    <S id="Y2_kiukay_ma01_S2">
        <FORM>e tja bungka</FORM>
        <AUDIO start="53.58" end="55.28"/>
    </S>
    <S id="Y2_kiukay_ma01_S3">
        <FORM>tjara si na vecik nua sasekauljan i kiukay.</FORM>
        <AUDIO start="55.28" end="60.09"/>
    </S>
    <S id="Y2_kiukay_ma01_S4">
        <FORM>sa izua anga tja vecik a e maqati a tja e kituluin.</FORM>
        <AUDIO start="60.13" end="65.31"/>
    </S>
    <S id="Y2_kiukay_ma01_S5">
        <FORM>sa inika anga itjen a a mavarung tu</FORM>
        <AUDIO start="65.31" end="68.83"/>
    </S>
    <S id="Y2_kiukay_ma01_S6">
        <FORM>e madraudraw a tja kai a ta tja e bungka.</FORM>
        <AUDIO start="68.83" end="74.82"/>
    </S>
    <S id="Y2_kiukay_ma01_S7">
        <FORM>kemasi cuay e, inika aken a na e secacadja tua i kiukay.</FORM>
        <AUDIO start="74.82" end="81.1"/>
    </S>
    <S id="Y2_kiukay_ma01_S8">
        <FORM>e ki saciur ki</FORM>
        <AUDIO start="81.11" end="82.72"/>
    </S>
    <S id="Y2_kiukay_ma01_S9">
        <FORM>kicaciuran aken</FORM>
        <AUDIO start="82.77" end="84.23"/>
    </S>
    <S id="Y2_kiukay_ma01_S10">
        <FORM>tua ramaljemaljeng</FORM>
        <AUDIO start="84.24" end="85.69"/>
    </S>
    <S id="Y2_kiukay_ma01_S11">
        <FORM>nu izua si lihalihayan</FORM>
        <AUDIO start="85.69" end="88.02"/>
    </S>
    <S id="Y2_kiukay_ma01_S12">
        <FORM>sa e</FORM>
        <AUDIO start="88.02" end="89.98"/>
    </S>
    <S id="Y2_kiukay_ma01_S13">
        <FORM>kisaselang aken uta a pacun</FORM>
        <AUDIO start="90.01" end="92.5"/>
    </S>
    <S id="Y2_kiukay_ma01_S14">
        <FORM>a semenay tua sambika, semupu tua sisiu.</FORM>
        <AUDIO start="92.5" end="96.81"/>
    </S>
    <S id="Y2_kiukay_ma01_S15">
        <FORM>nu tjemawcikel tua kai a e sasekauljan a cemas a bukasi,</FORM>
        <AUDIO start="96.81" end="102.12"/>
    </S>
    <S id="Y2_kiukay_ma01_S16">
        <FORM>na kisacalinga aken aravac</FORM>
        <AUDIO start="102.12" end="104.58"/>
    </S>
    <S id="Y2_kiukay_ma01_S17">
        <FORM>tua sinitjawcikel</FORM>
        <AUDIO start="104.58" end="106.15"/>
    </S>
    <S id="Y2_kiukay_ma01_S18">
        <FORM>nua sasekauljan a</FORM>
        <AUDIO start="106.17" end="107.81"/>
    </S>
    <S id="Y2_kiukay_ma01_S19">
        <FORM>e mara bukasi a penaiwanan.</FORM>
        <AUDIO start="107.82" end="111.88"/>
    </S>
</TEXT>
