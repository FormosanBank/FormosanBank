<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_the_meaning_of_spear_ball_ku01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: the meaning of spear ball_ku01 1 min.eaf; anonymized speaker label: ku01" audio="the meaning of spear ball_ku01.wav" dialect="Eastern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_the_meaning_of_spear_ball_ku01_S1">
        <FORM>izua izua na kisang seman qapuruqupurung a caucau i ta maza mama mazazangiljan.</FORM>
        <AUDIO start="80.6" end="88.69"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S2">
        <FORM>mazazangiljan a peniliq tu malje tapuluq a qapurung</FORM>
        <AUDIO start="88.69" end="93.54"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S3">
        <FORM>katua pinazuljuan tua uri sikivangvangvang nua nu djemuljar.</FORM>
        <AUDIO start="93.54" end="101.32"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S4">
        <FORM>a zua malje tapuluq a peniliq na mazazangiljan a qapurung,</FORM>
        <AUDIO start="101.32" end="107.5"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S5">
        <FORM>uri papu</FORM>
        <AUDIO start="107.5" end="109.36"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S6">
        <FORM>uri pasapuvuvuan anga na</FORM>
        <AUDIO start="109.36" end="111.43"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S7">
        <FORM>a sa palisi palisian na a</FORM>
        <AUDIO start="111.43" end="115.37"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S8">
        <FORM>patje tjumalj</FORM>
        <AUDIO start="115.37" end="117.1"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S9">
        <FORM>tu tua tja vuvu a na vengqac</FORM>
        <AUDIO start="117.1" end="119.59"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S10">
        <FORM>na pulingaw a pasusangas.</FORM>
        <AUDIO start="119.59" end="122.36"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S11">
        <FORM>nu kemacuvungan a itjen tucu a palisian,</FORM>
        <AUDIO start="122.36" end="126.82"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S12">
        <FORM>kacuin a pasa djadjulatan</FORM>
        <AUDIO start="126.82" end="129.87"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S13">
        <FORM>na pareqaljay</FORM>
        <AUDIO start="129.87" end="131.53"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S14">
        <FORM>tu sidjulat nua lalakacan.</FORM>
        <AUDIO start="131.53" end="135.67"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S15">
        <FORM>a malje tapuluq a</FORM>
        <AUDIO start="135.67" end="138.24"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S16">
        <FORM>palje pinalisian a qapurung,</FORM>
        <AUDIO start="138.25" end="140.67"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S17">
        <FORM>mareti maljimalji a pinungadan pinungadanan</FORM>
        <AUDIO start="140.67" end="144.2"/>
    </S>
    <S id="Y2_the_meaning_of_spear_ball_ku01_S18">
        <FORM>katua patalevan.</FORM>
        <AUDIO start="144.2" end="146.18"/>
    </S>
</TEXT>
