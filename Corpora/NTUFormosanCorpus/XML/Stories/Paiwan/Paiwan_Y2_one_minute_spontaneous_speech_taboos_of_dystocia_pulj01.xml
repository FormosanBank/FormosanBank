<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_taboos_of_dystocia_pulj01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: taboos of dystocia_pulj01 1 min.eaf; anonymized speaker label: pulj01" audio="taboos of dystocia_pulj01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_taboos_of_dystocia_pulj01_S1">
        <FORM>izua a vuvu ti marekerek anga.</FORM>
        <AUDIO start="2.99" end="5.985"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S2">
        <FORM>a ta zua sinipacay nimadju aya, palisi.</FORM>
        <AUDIO start="6.433" end="10.192"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S3">
        <FORM>anema a palisi?</FORM>
        <AUDIO start="10.192" end="11.44"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S4">
        <FORM>a vavayan nu nemapawlan pualjak sa macay aya.</FORM>
        <AUDIO start="11.44" end="15.912"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S5">
        <FORM>a za na matazua ini a bulay sinipacay a palisi aya.</FORM>
        <AUDIO start="15.912" end="19.99"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S6">
        <FORM>qau azazua macay timadju.</FORM>
        <AUDIO start="20.649" end="23.671"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S7">
        <FORM>a cikenaya a mare caucau tjaimadju se nimitja a a kinacauvan.</FORM>
        <AUDIO start="24.342" end="30.906"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S8">
        <FORM>amin a valjaw dikilu aya.</FORM>
        <AUDIO start="30.906" end="33.085"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S9">
        <FORM>a za vuvu anga ti simura.</FORM>
        <AUDIO start="33.486" end="36.674"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S10">
        <FORM>a za simura na dripung a kai aicu.</FORM>
        <AUDIO start="36.674" end="39.643"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S11">
        <FORM>a na a na paiwan a kai ti kudradrungan.</FORM>
        <AUDIO start="39.86" end="42.536"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S12">
        <FORM>qau macay ta zua qau aicu a na na macay qau a ku vuvu a ku vuvu anga a ti ti marekerek, dikinay a se a cevelj izui ta nimitja a caceveljan.</FORM>
        <AUDIO start="43.225" end="54.172"/>
    </S>
    <S id="Y2_taboos_of_dystocia_pulj01_S13">
        <FORM>qau manu a za ku vuvu a za ku vuvu anga ti simura ti kudrandrungan e ama aya itjen ta zua e siayain a za si siaya si izua a siaya ta zua a siayain.</FORM>
        <AUDIO start="55.509" end="66.889"/>
    </S>
</TEXT>
