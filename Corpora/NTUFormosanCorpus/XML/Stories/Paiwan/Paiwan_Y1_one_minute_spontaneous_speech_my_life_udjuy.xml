<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y1_one_minute_spontaneous_speech_my_life_udjuy" xml:lang="pwn" source="NTU Corpus, Paiwan, Y1 one-minute spontaneous speech; source EAF: my life_udjuy 1 min.eaf; anonymized speaker label: udjuy" audio="my life_udjuy.wav" dialect="Eastern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y1_my_life_udjuy_S1">
        <FORM>pai na kitululu aken i sivitay i tua</FORM>
        <AUDIO start="227.862" end="230.764"/>
    </S>
    <S id="Y1_my_life_udjuy_S2">
        <FORM>ta azua ljemanguaq ta ziduziya itjen</FORM>
        <AUDIO start="230.765" end="233.824"/>
    </S>
    <S id="Y1_my_life_udjuy_S3">
        <FORM>imaza ni e imazi aken i i i izua i i lizuk</FORM>
        <AUDIO start="233.921" end="240.117"/>
    </S>
    <S id="Y1_my_life_udjuy_S4">
        <FORM>avan anga azua, e seman kuban.</FORM>
        <AUDIO start="240.195" end="243.784"/>
    </S>
    <S id="Y1_my_life_udjuy_S5">
        <FORM>ta siuli ta ziduziya aya itjen.</FORM>
        <AUDIO start="243.784" end="247.804"/>
    </S>
    <S id="Y1_my_life_udjuy_S6">
        <FORM>avan azua sinipatagiljan ka djemalun aken,</FORM>
        <AUDIO start="247.804" end="250.901"/>
    </S>
    <S id="Y1_my_life_udjuy_S7">
        <FORM>e tjelu puluq</FORM>
        <AUDIO start="250.941" end="253.627"/>
    </S>
    <S id="Y1_my_life_udjuy_S8">
        <FORM>a ku cavilj avan a e na puvaljaw aken tauta izua anga ku aljak.</FORM>
        <AUDIO start="253.627" end="259.529"/>
    </S>
    <S id="Y1_my_life_udjuy_S9">
        <FORM>avan a za nia nasi</FORM>
        <AUDIO start="259.666" end="262.234"/>
    </S>
    <S id="Y1_my_life_udjuy_S10">
        <FORM>e djumakan ta niaken a ta sengsengan.</FORM>
        <AUDIO start="262.353" end="265.019"/>
    </S>
    <S id="Y1_my_life_udjuy_S11">
        <FORM>au karakudakuda aken i kuba, siuli aken ta zidusiya</FORM>
        <AUDIO start="265.019" end="269.823"/>
    </S>
    <S id="Y1_my_life_udjuy_S12">
        <FORM>tu tu cavilj nu izuazua zikan.</FORM>
        <AUDIO start="269.823" end="275"/>
    </S>
    <S id="Y1_my_life_udjuy_S13">
        <FORM>e na vaik aken temakesi a kitulu ta nimitja a pinaiwanan a vecik a kai.</FORM>
        <AUDIO start="275" end="281.392"/>
    </S>
    <S id="Y1_my_life_udjuy_S14">
        <FORM>aya itjen au manguaq ka secig ka semeking aken ta nimitja a paiwan a sini</FORM>
        <AUDIO start="281.392" end="290.96"/>
    </S>
    <S id="Y1_my_life_udjuy_S15">
        <FORM>pasasekiseking ta azua rumapining a itjen ta a kai.</FORM>
        <AUDIO start="290.96" end="295.666"/>
    </S>
</TEXT>
