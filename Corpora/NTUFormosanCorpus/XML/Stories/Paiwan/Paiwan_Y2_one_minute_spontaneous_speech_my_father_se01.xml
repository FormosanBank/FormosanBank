<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_my_father_se01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: my father_se01 1 min.eaf; anonymized speaker label: se01" audio="my father_se01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_my_father_se01_S1">
        <FORM>a maka ku salasaladj nu lemangda</FORM>
        <AUDIO start="53.508" end="56.781"/>
    </S>
    <S id="Y2_my_father_se01_S2">
        <FORM>mintjus manu makaya kanen a za qatjuvitjuvi aya.</FORM>
        <AUDIO start="56.781" end="60.963"/>
    </S>
    <S id="Y2_my_father_se01_S3">
        <FORM>inika a qatjuvitjuvi aya na qivu, pulj aya.</FORM>
        <AUDIO start="60.963" end="65.218"/>
    </S>
    <S id="Y2_my_father_se01_S4">
        <FORM>ljakua tjengelay amen aravac a marekaka marekakakaka a keman ta pulj.</FORM>
        <AUDIO start="65.218" end="71.618"/>
    </S>
    <S id="Y2_my_father_se01_S5">
        <FORM>pai nu na kemacu ti kama ita sakamaya, kedri pai.</FORM>
        <AUDIO start="71.636" end="78.181"/>
    </S>
    <S id="Y2_my_father_se01_S6">
        <FORM>kicakav a pakan tjanuaken a za kemeljang timadju tu tjengelay aken aravac a keman ta pulj.</FORM>
        <AUDIO start="78.199" end="85.291"/>
    </S>
    <S id="Y2_my_father_se01_S7">
        <FORM>a za pulj, nu tja cinapa, sarum aravac.</FORM>
        <AUDIO start="85.291" end="90.872"/>
    </S>
    <S id="Y2_my_father_se01_S8">
        <FORM>sanguaq aravac uta.</FORM>
        <AUDIO start="90.872" end="93.418"/>
    </S>
    <S id="Y2_my_father_se01_S9">
        <FORM>izua nu videvid.</FORM>
        <AUDIO start="93.418" end="98.181"/>
    </S>
    <S id="Y2_my_father_se01_S10">
        <FORM>inika na keman anga a mareka ku salasaladj tua pu tua pulj kata videvid.</FORM>
        <AUDIO start="98.199" end="104.854"/>
    </S>
    <S id="Y2_my_father_se01_S11">
        <FORM>manu makaya kanen aya timadju.</FORM>
        <AUDIO start="104.854" end="110.145"/>
    </S>
    <S id="Y2_my_father_se01_S12">
        <FORM>ti kama liav aravac a za palisi nimadju.</FORM>
        <AUDIO start="110.145" end="115.09"/>
    </S>
    <S id="Y2_my_father_se01_S13">
        <FORM>nakuya ma pana aya.</FORM>
        <AUDIO start="115.09" end="117.8"/>
    </S>
</TEXT>
