<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_savanguljan_tja01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: savanguljan_tja01 1 min.eaf; anonymized speaker label: tja01" audio="savanguljan_tja01.wav" dialect="Eastern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_savanguljan_tja01_S1">
        <FORM>pakingking anga tiamadju ta aicu a sinigaku.</FORM>
        <AUDIO start="82.47" end="87.44"/>
    </S>
    <S id="Y2_savanguljan_tja01_S2">
        <FORM>sau nu vaik ang vaik anga tiamadju a sema vavua.</FORM>
        <AUDIO start="87.44" end="92.58"/>
    </S>
    <S id="Y2_savanguljan_tja01_S3">
        <FORM>izua a masan kinakina.</FORM>
        <AUDIO start="92.58" end="95.52"/>
    </S>
    <S id="Y2_savanguljan_tja01_S4">
        <FORM>izua anga aljak a macidilj imaza i tjumaq.</FORM>
        <AUDIO start="95.52" end="99.61"/>
    </S>
    <S id="Y2_savanguljan_tja01_S5">
        <FORM>djumbi ta kemamain.</FORM>
        <AUDIO start="99.61" end="102.54"/>
    </S>
    <S id="Y2_savanguljan_tja01_S6">
        <FORM>a sicuayan a nimitja a kemanain</FORM>
        <AUDIO start="102.54" end="107.3"/>
    </S>
    <S id="Y2_savanguljan_tja01_S7">
        <FORM>a kinasan a pinuljacengan ta s</FORM>
        <AUDIO start="107.3" end="111.63"/>
    </S>
    <S id="Y2_savanguljan_tja01_S8">
        <FORM>sa sacem sa ta samaq</FORM>
        <AUDIO start="111.63" end="114.73"/>
    </S>
    <S id="Y2_savanguljan_tja01_S9">
        <FORM>vurasi a penuljat</FORM>
        <AUDIO start="114.73" end="116.99"/>
    </S>
    <S id="Y2_savanguljan_tja01_S10">
        <FORM>namatazua a kakanen</FORM>
        <AUDIO start="117" end="119.79"/>
    </S>
    <S id="Y2_savanguljan_tja01_S11">
        <FORM>aicu a tiamadju a savanguljan i pavua</FORM>
        <AUDIO start="119.79" end="124.24"/>
    </S>
    <S id="Y2_savanguljan_tja01_S12">
        <FORM>aicu a sema tjumaq</FORM>
        <AUDIO start="124.24" end="127.25"/>
    </S>
    <S id="Y2_savanguljan_tja01_S13">
        <FORM>aicu a sema tjumaq anga</FORM>
        <AUDIO start="127.25" end="129.46"/>
    </S>
    <S id="Y2_savanguljan_tja01_S14">
        <FORM>nu masulem</FORM>
        <AUDIO start="129.46" end="130.85"/>
    </S>
    <S id="Y2_savanguljan_tja01_S15">
        <FORM>a uqaljaqaljay a sika ki kikasiw.</FORM>
        <AUDIO start="130.85" end="135.92"/>
    </S>
    <S id="Y2_savanguljan_tja01_S16">
        <FORM>izua san kikasiw a macidilj.</FORM>
        <AUDIO start="135.92" end="138.84"/>
    </S>
    <S id="Y2_savanguljan_tja01_S17">
        <FORM>tu kacuin a kasiw nu masulem a sema tjumaq</FORM>
        <AUDIO start="138.84" end="143.01"/>
    </S>
    <S id="Y2_savanguljan_tja01_S18">
        <FORM>qau kinikasiw niamadju.</FORM>
        <AUDIO start="143.01" end="145.86"/>
    </S>
</TEXT>
