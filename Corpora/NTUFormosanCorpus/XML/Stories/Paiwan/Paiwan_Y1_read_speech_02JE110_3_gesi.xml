    <S id="Y1_02JE110_3_gesi_S1">
        <FORM>ita nia sikataqaljan,</FORM>
        <AUDIO start="3.585" end="6.082"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S2">
        <FORM>a uqaljaqaljay palaing tu macaqu a qemaljup,</FORM>
        <AUDIO start="6.375" end="10.23"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S3">
        <FORM>satja si qivu tana</FORM>
        <AUDIO start="11.227" end="13.207"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S4">
        <FORM>sepuwalang ta</FORM>
        <AUDIO start="13.477" end="14.754"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S5">
        <FORM>qaqaljupan na i cemiyul,</FORM>
        <AUDIO start="15.34" end="18.305"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S6">
        <FORM>timadju tja sinan</FORM>
        <AUDIO start="19.125" end="20.625"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S7">
        <FORM>“kisan cemiyul” kata “kisan</FORM>
        <AUDIO start="20.93" end="23.344"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S8">
        <FORM>pasepucug”.</FORM>
        <AUDIO start="23.672" end="25.277"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S9">
        <FORM>saka nu uqaljay sun,</FORM>
        <AUDIO start="26.543" end="28.664"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S10">
        <FORM>nu djemaljun a pitju,</FORM>
        <AUDIO start="29.074" end="31.301"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S11">
        <FORM>alu a cavilj tazua,</FORM>
        <AUDIO start="31.734" end="34.16"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S12">
        <FORM>si djaulj ta para</FORM>
        <AUDIO start="34.91" end="37.395"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S13">
        <FORM>parakaljay</FORM>
        <AUDIO start="37.875" end="39.035"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S14">
        <FORM>sasu</FORM>
        <AUDIO start="40.266" end="41.191"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S15">
        <FORM>sanluqeman</FORM>
        <AUDIO start="41.859" end="43.441"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S16">
        <FORM>a pari</FORM>
        <AUDIO start="43.605" end="44.496"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S17">
        <FORM>pairava</FORM>
        <AUDIO start="45.492" end="46.664"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S18">
        <FORM>ta tjakit,</FORM>
        <AUDIO start="47.355" end="48.316"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S19">
        <FORM>ulja sun a</FORM>
        <AUDIO start="49.09" end="50.109"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S20">
        <FORM>puvarung saka</FORM>
        <AUDIO start="50.566" end="51.879"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S21">
        <FORM>napupicul,</FORM>
        <AUDIO start="52.16" end="53.472"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S22">
        <FORM>a qemaljup a kiqeci.</FORM>
        <AUDIO start="54.352" end="56.473"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S23">
        <FORM>i “qaqaljupan” avan nusi</FORM>
        <AUDIO start="60.844" end="63.703"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S24">
        <FORM>kungkuan,</FORM>
        <AUDIO start="64.289" end="65.156"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S25">
        <FORM>sa</FORM>
        <AUDIO start="68.332" end="68.965"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S26">
        <FORM>sangsangasan a tja kituluin</FORM>
        <AUDIO start="70.688" end="73.559"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S27">
        <FORM>avanzua “kipu</FORM>
        <AUDIO start="73.769" end="75.339"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S28">
        <FORM>kipucug ta sacemel”.</FORM>
        <AUDIO start="75.656" end="77.906"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S29">
        <FORM>nu madjaljun anga</FORM>
        <AUDIO start="78.633" end="80.426"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S30">
        <FORM>ta puluqe sa pitju,</FORM>
        <AUDIO start="80.484" end="82.512"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S31">
        <FORM>alu a su cavilj,</FORM>
        <AUDIO start="83.098" end="85.066"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S32">
        <FORM>saka a su tarivakan a su picul</FORM>
        <AUDIO start="85.77" end="89.566"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S33">
        <FORM>na maqati anga,</FORM>
        <AUDIO start="89.953" end="91.336"/>
    </S>
    <S id="Y1_02JE110_3_gesi_S34">
        <FORM>ui si paka</FORM>
        <AUDIO start="92.918" end="94.559"/>
    </S>
</TEXT>
