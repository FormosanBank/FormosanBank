<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_masalut_tji01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: masalut_tji01 1 min.eaf; anonymized speaker label: tji01" audio="masalut_tji01.wav" dialect="Central Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_masalut_tji01_S1">
        <FORM>aicu a sangasan a pazangal,</FORM>
        <AUDIO start="63.68" end="66.19"/>
    </S>
    <S id="Y2_masalut_tji01_S2">
        <FORM>avan cu a a tja sinitalem a vaqu.</FORM>
        <AUDIO start="66.22" end="71.27"/>
    </S>
    <S id="Y2_masalut_tji01_S3">
        <FORM>avan cu a vaqu a tja pinaqalayan.</FORM>
        <AUDIO start="71.27" end="73.9"/>
    </S>
    <S id="Y2_masalut_tji01_S4">
        <FORM>a cu a vaqu angata lialiav angata milimilingan.</FORM>
        <AUDIO start="73.9" end="78.19"/>
    </S>
    <S id="Y2_masalut_tji01_S5">
        <FORM>kemasi sicuayan, avan cu a tja kalamian</FORM>
        <AUDIO start="78.19" end="81.73"/>
    </S>
    <S id="Y2_masalut_tji01_S6">
        <FORM>avan cu a tja a sikavaljuvaljutan</FORM>
        <AUDIO start="81.73" end="85.47"/>
    </S>
    <S id="Y2_masalut_tji01_S7">
        <FORM>a tja kalamian</FORM>
        <AUDIO start="85.49" end="86.98"/>
    </S>
    <S id="Y2_masalut_tji01_S8">
        <FORM>pai aicu a vaqu ta sicuayan a milimilingan sinipavay na azua tja sangasangasan</FORM>
        <AUDIO start="86.98" end="95.03"/>
    </S>
    <S id="Y2_masalut_tji01_S9">
        <FORM>a semaimaza i kacuan a caucaw.</FORM>
        <AUDIO start="95.05" end="97.86"/>
    </S>
    <S id="Y2_masalut_tji01_S10">
        <FORM>a aicu e e sitaletalem ku ayavaw</FORM>
        <AUDIO start="97.86" end="103.43"/>
    </S>
    <S id="Y2_masalut_tji01_S11">
        <FORM>pai avan cu sangasang nu masalut nu aya angata</FORM>
        <AUDIO start="103.44" end="107.89"/>
    </S>
    <S id="Y2_masalut_tji01_S12">
        <FORM>nu maka kivaqu itjen</FORM>
        <AUDIO start="107.89" end="110.99"/>
    </S>
    <S id="Y2_masalut_tji01_S13">
        <FORM>avan cu anga tja sikasalev</FORM>
        <AUDIO start="110.99" end="112.94"/>
    </S>
    <S id="Y2_masalut_tji01_S14">
        <FORM>avan cu anga tja sikasalev tucu a a a qadaw.</FORM>
        <AUDIO start="112.94" end="118.15"/>
    </S>
    <S id="Y2_masalut_tji01_S15">
        <FORM>aicu a tja suvalitan</FORM>
        <AUDIO start="118.15" end="119.98"/>
    </S>
    <S id="Y2_masalut_tji01_S16">
        <FORM>aicu a tja kemasi izua ti zua anga tja vuvu.</FORM>
        <AUDIO start="119.98" end="123.19"/>
    </S>
</TEXT>
