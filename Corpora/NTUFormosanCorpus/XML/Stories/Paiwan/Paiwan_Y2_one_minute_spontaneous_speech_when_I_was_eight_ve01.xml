<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_when_I_was_eight_ve01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: when I was eight_ve01 1 min.eaf; anonymized speaker label: ve01" audio="when I was eight_ve01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_when_I_was_eight_ve01_S1">
        <FORM>manu kemuda aya anga aken.</FORM>
        <AUDIO start="57.55" end="60.611"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S2">
        <FORM>a nia qinaljan, izua tjalitiv.</FORM>
        <AUDIO start="60.611" end="64.222"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S3">
        <FORM>ta nia pana, dudut ta qinaljan.</FORM>
        <AUDIO start="64.222" end="67.402"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S4">
        <FORM>nu kaljaqudjaljan, qaca aravac a zaljum.</FORM>
        <AUDIO start="67.402" end="71.486"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S5">
        <FORM>cemepeng ta pana.</FORM>
        <AUDIO start="71.486" end="73.402"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S6">
        <FORM>izua nu uri cevacaq anga ta qinaljan</FORM>
        <AUDIO start="73.402" end="77.027"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S7">
        <FORM>na marekutj amen aravac.</FORM>
        <AUDIO start="77.027" end="81.18"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S8">
        <FORM>ka i viljilj anga, vulingen anga na pana.</FORM>
        <AUDIO start="81.18" end="84.805"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S9">
        <FORM>ini anga amen a magagalj</FORM>
        <AUDIO start="84.805" end="86.818"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S10">
        <FORM>tu qaljudjen a qinaljan.</FORM>
        <AUDIO start="86.888" end="90.333"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S11">
        <FORM>nu kaljaqudjaljan,</FORM>
        <AUDIO start="90.333" end="92.514"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S12">
        <FORM>pacengceng uta puravay a situ</FORM>
        <AUDIO start="92.514" end="95.764"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S13">
        <FORM>ta kaljazurukan.</FORM>
        <AUDIO start="95.764" end="98.847"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S14">
        <FORM>tjuruvu a caucaw a sema tjalitiv a ljemanguy.</FORM>
        <AUDIO start="98.847" end="103.263"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S15">
        <FORM>kumali a bairang sema mazamaza a ljemanguy</FORM>
        <AUDIO start="103.263" end="108.083"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S16">
        <FORM>a talidu ta qaca a zaljum</FORM>
        <AUDIO start="108.083" end="110.944"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S17">
        <FORM>a makelukelu i tjalitiv.</FORM>
        <AUDIO start="110.944" end="113.916"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S18">
        <FORM>samali tiamadju</FORM>
        <AUDIO start="113.916" end="115.569"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S19">
        <FORM>saka kisuzalangzangan uta.</FORM>
        <AUDIO start="115.569" end="118.888"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S20">
        <FORM>izua ka makatalj</FORM>
        <AUDIO start="118.888" end="120.833"/>
    </S>
    <S id="Y2_when_I_was_eight_ve01_S21">
        <FORM>guaguagua amen i vavua.</FORM>
        <AUDIO start="120.833" end="124.569"/>
    </S>
</TEXT>
