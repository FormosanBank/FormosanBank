<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_local_daycare_and_language_revitalization_il01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: local daycare and language revitalization_il01 1 min.eaf; anonymized speaker label: il01" audio="local daycare and language revitalization_il01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_local_daycare_and_language_revitalization_il01_S1">
        <FORM>e tucu a uri a ku sipasemalaw</FORM>
        <AUDIO start="0.98" end="4.901"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S2">
        <FORM>avan aicu a na</FORM>
        <AUDIO start="4.901" end="7.411"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S3">
        <FORM>e tucu a cavilj</FORM>
        <AUDIO start="7.411" end="10"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S4">
        <FORM>a na lemingdjelj aken tua za paka a ta za yucing yucingan.</FORM>
        <AUDIO start="10" end="15.411"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S5">
        <FORM>a a za nia a za nia yucingan nu aya itjen</FORM>
        <AUDIO start="15.411" end="19.548"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S6">
        <FORM>avan anga a qivuivu tua a tja vinuculjan a a kitulu</FORM>
        <AUDIO start="19.548" end="25.686"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S7">
        <FORM>a tua situcuan a kakudan</FORM>
        <AUDIO start="25.686" end="28.666"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S8">
        <FORM>katua si e sitjay sangasangasan.</FORM>
        <AUDIO start="28.686" end="31.666"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S9">
        <FORM>aku azua e lemingdjelj aken ta aicu a na matucu nu aya itjen</FORM>
        <AUDIO start="31.666" end="36.881"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S10">
        <FORM>a ki kemasi inu aken a patagalj a lem a a kinemenem?</FORM>
        <AUDIO start="36.901" end="42.411"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S11">
        <FORM>e cuacuay aken a kinemenemenem a tua</FORM>
        <AUDIO start="42.411" end="45.921"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S12">
        <FORM>e lemingdjelj a ta aicu a</FORM>
        <AUDIO start="45.941" end="48.235"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S13">
        <FORM>e tatuluan tua kakedrian tua paka ta kinacalisianan</FORM>
        <AUDIO start="48.235" end="52.588"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S14">
        <FORM>aku azua itjen a niaken a singmung</FORM>
        <AUDIO start="52.588" end="56.431"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S15">
        <FORM>avan a za kilalaing tua vavuluvulungan.</FORM>
        <AUDIO start="56.431" end="59.921"/>
    </S>
    <S id="Y2_local_daycare_and_language_revitalization_il01_S16">
        <FORM>tapuluq ha alu anga aken a cavilj a kilalailaing tua vavuluvulungan.</FORM>
        <AUDIO start="59.96" end="65.47"/>
    </S>
</TEXT>
