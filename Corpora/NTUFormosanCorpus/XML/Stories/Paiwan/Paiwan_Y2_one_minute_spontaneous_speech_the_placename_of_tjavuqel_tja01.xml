<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_the_placename_of_tjavuqel_tja01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: the placename of tjavuqel_tja01 1 min.eaf; anonymized speaker label: tja01" audio="the placename of tjavuqel_tja01.wav" dialect="Eastern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_the_placename_of_tjavuqel_tja01_S1">
        <FORM>izua a milimilingan a se tjavuqel a na mayatucu.</FORM>
        <AUDIO start="1.15" end="6.07"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S2">
        <FORM>kasi cuayan nu sema maza i qinaljan a za nia sikataqlan a kemasi cuayan a qinaljan.</FORM>
        <AUDIO start="6.07" end="13.59"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S3">
        <FORM>uri kikasiw tiamadju tu temabaw, tu seman umaqan.</FORM>
        <AUDIO start="13.59" end="18.55"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S4">
        <FORM>qau a za kasiw, veneva anga aya a nia siayan</FORM>
        <AUDIO start="18.55" end="23.48"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S5">
        <FORM>mintjus tiamadju</FORM>
        <AUDIO start="23.48" end="25.48"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S6">
        <FORM>sa maljaljavar tiamadju.</FORM>
        <AUDIO start="25.48" end="28.53"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S7">
        <FORM>bulay aravac a pa kadjunangan imaza aya a za tja ramaljemaljeng.</FORM>
        <AUDIO start="28.53" end="34.29"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S8">
        <FORM>sa papungadan tiamadju ta aicu a ka kadjunangan.</FORM>
        <AUDIO start="34.29" end="39.29"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S9">
        <FORM>katjavuqelan, aya.</FORM>
        <AUDIO start="39.29" end="41.54"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S10">
        <FORM>se tjavuqel amen, aya.</FORM>
        <AUDIO start="41.54" end="43.5"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S11">
        <FORM>sa akumaya a pinika tjavuqel amen.</FORM>
        <AUDIO start="43.5" end="47.17"/>
    </S>
    <S id="Y2_the_placename_of_tjavuqel_tja01_S12">
        <FORM>mavan aicu a miliman aya a nia ramaljemaljeng.</FORM>
        <AUDIO start="47.17" end="51.62"/>
    </S>
</TEXT>
