<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_frog_ve01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: frog_ve01 1 min.eaf; anonymized speaker label: ve01" audio="frog_ve01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_frog_ve01_S1">
        <FORM>vaik tiamadju a a ma sasav a kipakim ta zua a kiyav.</FORM>
        <AUDIO start="124.2" end="129.466"/>
    </S>
    <S id="Y2_frog_ve01_S2">
        <FORM>a tjarawtjawtjaw ti kapi.</FORM>
        <AUDIO start="129.466" end="132.399"/>
    </S>
    <S id="Y2_frog_ve01_S3">
        <FORM>inua anga un? ayain a za kiyav.</FORM>
        <AUDIO start="132.399" end="135.666"/>
    </S>
    <S id="Y2_frog_ve01_S4">
        <FORM>ki ayain a za vatu uta kitaivililj.</FORM>
        <AUDIO start="135.666" end="139.767"/>
    </S>
    <S id="Y2_frog_ve01_S5">
        <FORM>manu makelu ti vatu a kemasi tua qezung.</FORM>
        <AUDIO start="139.767" end="144.333"/>
    </S>
    <S id="Y2_frog_ve01_S6">
        <FORM>mapeta a za kindraljun.</FORM>
        <AUDIO start="144.333" end="148.1"/>
    </S>
    <S id="Y2_frog_ve01_S7">
        <FORM>sa tapuluin a za vatu ni kapi.</FORM>
        <AUDIO start="148.1" end="153.533"/>
    </S>
    <S id="Y2_frog_ve01_S8">
        <FORM>ini sun a na makuda? ayain.</FORM>
        <AUDIO start="153.533" end="157.067"/>
    </S>
    <S id="Y2_frog_ve01_S9">
        <FORM>a sa vaik tiamadju a ma sasaw a kipakim tazua kiyav.</FORM>
        <AUDIO start="157.067" end="165.333"/>
    </S>
    <S id="Y2_frog_ve01_S10">
        <FORM>a tjarawtjav ti kapi ta za kiyav, inua un? ayain.</FORM>
        <AUDIO start="165.333" end="173.233"/>
    </S>
    <S id="Y2_frog_ve01_S11">
        <FORM>a za vatu paqawqaw uta ta zua kiyav.</FORM>
        <AUDIO start="173.233" end="180.599"/>
    </S>
    <S id="Y2_frog_ve01_S12">
        <FORM>a ma ma zua i pukasivan a kipakim.</FORM>
        <AUDIO start="180.599" end="186.166"/>
    </S>
</TEXT>
