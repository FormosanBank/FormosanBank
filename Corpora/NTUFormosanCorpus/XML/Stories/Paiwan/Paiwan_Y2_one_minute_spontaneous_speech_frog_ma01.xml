<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_frog_ma01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: frog_ma01 1 min.eaf; anonymized speaker label: ma01" audio="frog_ma01.wav" dialect="Southern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_frog_ma01_S1">
        <FORM>manu ka malia anga,</FORM>
        <AUDIO start="59.95" end="63.2"/>
    </S>
    <S id="Y2_frog_ma01_S2">
        <FORM>e pacun ti mili katua valu</FORM>
        <AUDIO start="63.236" end="66.289"/>
    </S>
    <S id="Y2_frog_ma01_S3">
        <FORM>katua vatu nimadju a ti siawhey a pasa izua i ta kana.</FORM>
        <AUDIO start="66.289" end="70.552"/>
    </S>
    <S id="Y2_frog_ma01_S4">
        <FORM>mintjus tiamadju, ayatua neka anga azua ceqel.</FORM>
        <AUDIO start="70.605" end="75.052"/>
    </S>
    <S id="Y2_frog_ma01_S5">
        <FORM>patagilj anga ti e mili a karim ta azua a ceqel.</FORM>
        <AUDIO start="75.052" end="80.868"/>
    </S>
    <S id="Y2_frog_ma01_S6">
        <FORM>arapen anga nimadju a e kucu.</FORM>
        <AUDIO start="80.868" end="84"/>
    </S>
    <S id="Y2_frog_ma01_S7">
        <FORM>e sicaca anga, pacunan anga</FORM>
        <AUDIO start="84" end="86.341"/>
    </S>
    <S id="Y2_frog_ma01_S8">
        <FORM>e a vatu nimadju a ti siawhey uta pusaladj a karim.</FORM>
        <AUDIO start="86.341" end="90.368"/>
    </S>
    <S id="Y2_frog_ma01_S9">
        <FORM>e pasataladjen a qulu na vatu a pasa ta kana.</FORM>
        <AUDIO start="90.368" end="93.999"/>
    </S>
    <S id="Y2_frog_ma01_S10">
        <FORM>e paljilji a karim ta zua a ceqel, manu ini a makadjumaq timadju.</FORM>
        <AUDIO start="93.999" end="98.947"/>
    </S>
    <S id="Y2_frog_ma01_S11">
        <FORM>semuqeljev ti mili ta e qezung.</FORM>
        <AUDIO start="98.973" end="102.105"/>
    </S>
    <S id="Y2_frog_ma01_S12">
        <FORM>na qaqelengan nimadju a ljemizaw a pasa sasaw a</FORM>
        <AUDIO start="102.105" end="106.026"/>
    </S>
    <S id="Y2_frog_ma01_S13">
        <FORM>e mezangal a qivu.</FORM>
        <AUDIO start="106.026" end="107.973"/>
    </S>
    <S id="Y2_frog_ma01_S14">
        <FORM>e ceqel, ceqel! ainu anga sun? ainu anga sun? aya mezangazangal a</FORM>
        <AUDIO start="107.973" end="113.368"/>
    </S>
    <S id="Y2_frog_ma01_S15">
        <FORM>qivuqivu ta azua ceqel nimadju.</FORM>
        <AUDIO start="113.368" end="116.026"/>
    </S>
    <S id="Y2_frog_ma01_S16">
        <FORM>e azua vatu uta</FORM>
        <AUDIO start="116.026" end="117.92"/>
    </S>
    <S id="Y2_frog_ma01_S17">
        <FORM>e kamayan anan a na e pini qulu a e</FORM>
        <AUDIO start="117.92" end="122.183"/>
    </S>
    <S id="Y2_frog_ma01_S18">
        <FORM>kana a gemurugurgur a qivuqivu a kararim uta a pusaladj ta e ceqel.</FORM>
        <AUDIO start="122.184" end="128.079"/>
    </S>
</TEXT>
