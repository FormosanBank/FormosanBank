<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_vassal_system_ku01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: vassal system_ku01 1 min.eaf; anonymized speaker label: ku01" audio="vassal system_ku01.wav" dialect="Eastern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_vassal_system_ku01_S1">
        <FORM>qau izua cinaucauan</FORM>
        <AUDIO start="21.85" end="24.82"/>
    </S>
    <S id="Y2_vassal_system_ku01_S2">
        <FORM>ka izua pupalisian</FORM>
        <AUDIO start="24.82" end="27.89"/>
    </S>
    <S id="Y2_vassal_system_ku01_S3">
        <FORM>katua tjaucikel a milimilingan.</FORM>
        <AUDIO start="27.89" end="32.21"/>
    </S>
    <S id="Y2_vassal_system_ku01_S4">
        <FORM>nu izua za a za maljelima</FORM>
        <AUDIO start="32.21" end="34.46"/>
    </S>
    <S id="Y2_vassal_system_ku01_S5">
        <FORM>au ma maqati a tiamadju na masan kina kisan mazazangiljan.</FORM>
        <AUDIO start="34.46" end="39.61"/>
    </S>
    <S id="Y2_vassal_system_ku01_S6">
        <FORM>qau a ku sitjaucikel aicu a mazazangiljan a pakasi tua e</FORM>
        <AUDIO start="39.61" end="46.32"/>
    </S>
    <S id="Y2_vassal_system_ku01_S7">
        <FORM>i lja patalinuk a mazazangiljan.</FORM>
        <AUDIO start="46.32" end="50.17"/>
    </S>
    <S id="Y2_vassal_system_ku01_S8">
        <FORM>a cina a mazaza ma mazazangilan</FORM>
        <AUDIO start="50.17" end="54.01"/>
    </S>
    <S id="Y2_vassal_system_ku01_S9">
        <FORM>ulja na kisan kisan kilalaing</FORM>
        <AUDIO start="54.01" end="56.71"/>
    </S>
    <S id="Y2_vassal_system_ku01_S10">
        <FORM>tua tja sikataqaljan a zua nimadju a pacugan.</FORM>
        <AUDIO start="56.71" end="60.46"/>
    </S>
    <S id="Y2_vassal_system_ku01_S11">
        <FORM>qau ulja nu kilalaing itjen tucu a tucu a tja sikataqaljan</FORM>
        <AUDIO start="60.46" end="66.2"/>
    </S>
    <S id="Y2_vassal_system_ku01_S12">
        <FORM>ljakua liaw aravac a sengsengan.</FORM>
        <AUDIO start="66.2" end="68.47"/>
    </S>
    <S id="Y2_vassal_system_ku01_S13">
        <FORM>liaw a uri tja kudain.</FORM>
        <AUDIO start="68.47" end="70.43"/>
    </S>
    <S id="Y2_vassal_system_ku01_S14">
        <FORM>qau izua cinacauan nua mazazangiljan.</FORM>
        <AUDIO start="70.43" end="75.01"/>
    </S>
    <S id="Y2_vassal_system_ku01_S15">
        <FORM>ulja na izua tja nimadju a sengsengan.</FORM>
        <AUDIO start="75.01" end="78.87"/>
    </S>
    <S id="Y2_vassal_system_ku01_S16">
        <FORM>lja lja ma mu saseqalj a mazazangiljan kilalaing tua sikataqaljan aya.</FORM>
        <AUDIO start="78.87" end="84.16"/>
    </S>
</TEXT>
