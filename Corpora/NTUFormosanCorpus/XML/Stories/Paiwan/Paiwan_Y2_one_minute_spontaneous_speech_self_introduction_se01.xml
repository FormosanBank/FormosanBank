<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_self_introduction_se01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: self introduction_se01 1 min.eaf; anonymized speaker label: se01" audio="self introduction_se01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_self_introduction_se01_S1">
        <FORM>tiaken ti selep a lja kalanian a se kazazaljan.</FORM>
        <AUDIO start="2.852" end="7.681"/>
    </S>
    <S id="Y2_self_introduction_se01_S2">
        <FORM>na pucikelj aken a pasa ma gaku i izuci.</FORM>
        <AUDIO start="7.681" end="12.556"/>
    </S>
    <S id="Y2_self_introduction_se01_S3">
        <FORM>ti paucan a lja tjurapalas a ku cikel.</FORM>
        <AUDIO start="12.556" end="16.307"/>
    </S>
    <S id="Y2_self_introduction_se01_S4">
        <FORM>matjelu a ku aljak, madrusa a vavayan, macidjilj a uqaljay.</FORM>
        <AUDIO start="16.307" end="24.397"/>
    </S>
    <S id="Y2_self_introduction_se01_S5">
        <FORM>ti dremedreman a ku kina.</FORM>
        <AUDIO start="24.397" end="27.193"/>
    </S>
    <S id="Y2_self_introduction_se01_S6">
        <FORM>ti legeay a ku kama.</FORM>
        <AUDIO start="27.193" end="29.965"/>
    </S>
    <S id="Y2_self_introduction_se01_S7">
        <FORM>masepatj amen a marekaka marekakaka.</FORM>
        <AUDIO start="29.965" end="36.181"/>
    </S>
    <S id="Y2_self_introduction_se01_S8">
        <FORM>izua madrusa a uqaljay, a ti giljigiljaw kati kuljilji.</FORM>
        <AUDIO start="36.181" end="43.283"/>
    </S>
    <S id="Y2_self_introduction_se01_S9">
        <FORM>macidjilj ti karesikes a ku kaka a vavayan.</FORM>
        <AUDIO start="43.283" end="49.294"/>
    </S>
    <S id="Y2_self_introduction_se01_S10">
        <FORM>inika macaqu aravac ti kama a cemukuku cemukukuan</FORM>
        <AUDIO start="49.294" end="55.079"/>
    </S>
    <S id="Y2_self_introduction_se01_S11">
        <FORM>manasika</FORM>
        <AUDIO start="55.079" end="57.602"/>
    </S>
    <S id="Y2_self_introduction_se01_S12">
        <FORM>nu kiljavaran tjai kama</FORM>
        <AUDIO start="57.602" end="60.136"/>
    </S>
    <S id="Y2_self_introduction_se01_S13">
        <FORM>kemacalisianan amen a tja cemekeljan.</FORM>
        <AUDIO start="60.136" end="63.738"/>
    </S>
</TEXT>
