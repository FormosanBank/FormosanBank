<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_the_man_who_killed_typhoon_pulj01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: the man who killed typhoon_pulj01 1 min.eaf; anonymized speaker label: pulj01" audio="the man who killed typhoon_pulj01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S1">
        <FORM>ay izua za lin linadengan a a milingan a matucu lja</FORM>
        <AUDIO start="2.826" end="8.021"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S2">
        <FORM>izua zai kedri anan niamen a caucau</FORM>
        <AUDIO start="8.249" end="10.338"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S3">
        <FORM>qadjaw tu timun za ngadan makarupangan</FORM>
        <AUDIO start="10.338" end="12.929"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S4">
        <FORM>e i za qadaw aya</FORM>
        <AUDIO start="13.55" end="15.43"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S5">
        <FORM>manu venalivali ta zua a mevenulivuli za vengin aya</FORM>
        <AUDIO start="15.627" end="19.576"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S6">
        <FORM>qau a za a za a za a za a za ti qadjaw tima za ngadan azua lja</FORM>
        <AUDIO start="20.227" end="25.169"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S7">
        <FORM>a za timadju aya</FORM>
        <AUDIO start="25.576" end="26.776"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S8">
        <FORM>matjavec ta za vali amaya qaca cu a vali ayaw</FORM>
        <AUDIO start="27.364" end="31.224"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S9">
        <FORM>a kacuin a za niamadju a pakadrusa</FORM>
        <AUDIO start="31.547" end="33.767"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S10">
        <FORM>laingen aya laingen a za pakadrusa e</FORM>
        <AUDIO start="33.767" end="37.47"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S11">
        <FORM>djemaljun a izuazua i matu i calavi tu i marupaljing ayaw</FORM>
        <AUDIO start="37.47" end="41.41"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S12">
        <FORM>qadjaw makarupangan lja</FORM>
        <AUDIO start="41.446" end="42.604"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S13">
        <FORM>qau a za pakadrusa manu puita na kinljuq a na za na vali a kula</FORM>
        <AUDIO start="43.252" end="49.659"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S14">
        <FORM>qau qau a ta zua e qivu timitja tucu</FORM>
        <AUDIO start="50.542" end="54.133"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S15">
        <FORM>ui neka anga a vali aya tiamadju aumaya aya</FORM>
        <AUDIO start="54.486" end="57.103"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S16">
        <FORM>u</FORM>
        <AUDIO start="57.368" end="58.201"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S17">
        <FORM>qau a kinljuq anga na vali a kula aya</FORM>
        <AUDIO start="58.201" end="61.009"/>
    </S>
    <S id="Y2_the_man_who_killed_typhoon_pulj01_S18">
        <FORM>a na matucu za niamen a linadengan a milingan</FORM>
        <AUDIO start="61.356" end="64.038"/>
    </S>
</TEXT>
