<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_self_introduction_tji01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: self introduction_tji01 1 min.eaf; anonymized speaker label: tji01" audio="self introduction_tji01.wav" dialect="Central Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_self_introduction_tji01_S1">
        <FORM>pai a sema gimen ta siu gaku</FORM>
        <AUDIO start="53.185" end="56.72"/>
    </S>
    <S id="Y2_self_introduction_tji01_S2">
        <FORM>kima izua lu kima izua e pida anga a su cavilj</FORM>
        <AUDIO start="56.72" end="60.79"/>
    </S>
    <S id="Y2_self_introduction_tji01_S3">
        <FORM>pasusangasen amen a ku kama katu ku kina</FORM>
        <AUDIO start="60.79" end="63.441"/>
    </S>
    <S id="Y2_self_introduction_tji01_S4">
        <FORM>azua nakuya ika kitulu ayen amen a ku kina</FORM>
        <AUDIO start="63.464" end="67.186"/>
    </S>
    <S id="Y2_self_introduction_tji01_S5">
        <FORM>pai vaik amen a ma zui i gimen a kitulu.</FORM>
        <AUDIO start="67.186" end="71"/>
    </S>
    <S id="Y2_self_introduction_tji01_S6">
        <FORM>pai aicu nu i tjumaq aicu a ku kinu kata ku kama</FORM>
        <AUDIO start="71" end="76.558"/>
    </S>
    <S id="Y2_self_introduction_tji01_S7">
        <FORM>tiamadju a madrusa</FORM>
        <AUDIO start="76.558" end="78.442"/>
    </S>
    <S id="Y2_self_introduction_tji01_S8">
        <FORM>nu maka gimen mun kitulu itjen ta lialiaw tua nemanga tua nemanga.</FORM>
        <AUDIO start="78.442" end="82.977"/>
    </S>
    <S id="Y2_self_introduction_tji01_S9">
        <FORM>kata nu i tjumaq itjen</FORM>
        <AUDIO start="82.977" end="85.538"/>
    </S>
    <S id="Y2_self_introduction_tji01_S10">
        <FORM>aicu a za sikiljavalan</FORM>
        <AUDIO start="85.538" end="87.413"/>
    </S>
    <S id="Y2_self_introduction_tji01_S11">
        <FORM>avan cu a pinayuanan ayen aken a ku kina kata ku kama.</FORM>
        <AUDIO start="87.413" end="92.047"/>
    </S>
    <S id="Y2_self_introduction_tji01_S12">
        <FORM>avan u ku kemai kakedrian za</FORM>
        <AUDIO start="92.047" end="95.307"/>
    </S>
    <S id="Y2_self_introduction_tji01_S13">
        <FORM>a kiljavalan tucu a pinayuanan.</FORM>
        <AUDIO start="95.307" end="98.768"/>
    </S>
    <S id="Y2_self_introduction_tji01_S14">
        <FORM>pai ka nu djemaljun amen a</FORM>
        <AUDIO start="98.768" end="100.923"/>
    </S>
    <S id="Y2_self_introduction_tji01_S15">
        <FORM>a kisitjaulj amen tucu a a</FORM>
        <AUDIO start="100.923" end="105.124"/>
    </S>
    <S id="Y2_self_introduction_tji01_S16">
        <FORM>siu gaku i gimen ku ayaw</FORM>
        <AUDIO start="105.124" end="107.509"/>
    </S>
    <S id="Y2_self_introduction_tji01_S17">
        <FORM>azua kimayan a kazima sa ku kama</FORM>
        <AUDIO start="107.509" end="110.471"/>
    </S>
    <S id="Y2_self_introduction_tji01_S18">
        <FORM>a pakitulu tjanuamen, pasazuain amen</FORM>
        <AUDIO start="110.49" end="113.605"/>
    </S>
    <S id="Y2_self_introduction_tji01_S19">
        <FORM>i lizuk.</FORM>
        <AUDIO start="113.605" end="114.989"/>
    </S>
</TEXT>
