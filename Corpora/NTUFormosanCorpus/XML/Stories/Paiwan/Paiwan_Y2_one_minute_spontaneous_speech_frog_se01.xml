<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_frog_se01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: frog_se01 1 min.eaf; anonymized speaker label: se01" audio="frog_se01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_frog_se01_S1">
        <FORM>manu ka djurungan a za kasiw na vatu,</FORM>
        <AUDIO start="176.323" end="181.028"/>
    </S>
    <S id="Y2_frog_se01_S2">
        <FORM>makelu a za tjainan.</FORM>
        <AUDIO start="181.088" end="184.088"/>
    </S>
    <S id="Y2_frog_se01_S3">
        <FORM>laingen tiamadju na tjainan.</FORM>
        <AUDIO start="184.088" end="188.206"/>
    </S>
    <S id="Y2_frog_se01_S4">
        <FORM>manu matjani ti ariv.</FORM>
        <AUDIO start="188.323" end="191.941"/>
    </S>
    <S id="Y2_frog_se01_S5">
        <FORM>pacun tua izua za ljequ i ta kasiw i vavav.</FORM>
        <AUDIO start="191.941" end="196.97"/>
    </S>
    <S id="Y2_frog_se01_S6">
        <FORM>ljequ, na pacun sun ta ku cikilj? aya ti ari tjay ljequ.</FORM>
        <AUDIO start="197.029" end="202.941"/>
    </S>
    <S id="Y2_frog_se01_S7">
        <FORM>sau, vaiku, aya ti ljequ. sauen a sauen ni ljequ.</FORM>
        <AUDIO start="202.999" end="207.882"/>
    </S>
    <S id="Y2_frog_se01_S8">
        <FORM>pai, ljevavav ti ariv ta qaciljay.</FORM>
        <AUDIO start="207.911" end="212.94"/>
    </S>
    <S id="Y2_frog_se01_S9">
        <FORM>manu pacun ta za ricing. ljevavaw timadju.</FORM>
        <AUDIO start="212.94" end="217.205"/>
    </S>
    <S id="Y2_frog_se01_S10">
        <FORM>manu garavagav a za ri ricing.</FORM>
        <AUDIO start="217.234" end="220.676"/>
    </S>
    <S id="Y2_frog_se01_S11">
        <FORM>em? anema aicu? aya ti ariv.</FORM>
        <AUDIO start="220.676" end="223.559"/>
    </S>
    <S id="Y2_frog_se01_S12">
        <FORM>manu venan.</FORM>
        <AUDIO start="223.617" end="225.735"/>
    </S>
    <S id="Y2_frog_se01_S13">
        <FORM>inika ricing a za kinaivavavan nimadju</FORM>
        <AUDIO start="225.735" end="229.941"/>
    </S>
    <S id="Y2_frog_se01_S14">
        <FORM>mintjus a za ti venan, manu undukay.</FORM>
        <AUDIO start="229.941" end="234.676"/>
    </S>
    <S id="Y2_frog_se01_S15">
        <FORM>ka undukay a vaik a za venan,</FORM>
        <AUDIO start="234.765" end="239.735"/>
    </S>
    <S id="Y2_frog_se01_S16">
        <FORM>djemaljun tiamadju tua cevaceva.</FORM>
        <AUDIO start="239.97" end="243.735"/>
    </S>
</TEXT>
