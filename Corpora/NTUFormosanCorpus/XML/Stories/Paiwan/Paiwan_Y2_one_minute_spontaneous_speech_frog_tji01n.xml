<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_frog_tji01n" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: frog_tji01n 1 min.eaf; anonymized speaker label: tji01" audio="frog_tji01n.wav" dialect="Central Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_frog_tji01n_S1">
        <FORM>pai ka na sekataqed anga amen,</FORM>
        <AUDIO start="31.203" end="35.898"/>
    </S>
    <S id="Y2_frog_tji01n_S2">
        <FORM>azua kimai iga cinaqavan izua vatjuku</FORM>
        <AUDIO start="35.898" end="39.949"/>
    </S>
    <S id="Y2_frog_tji01n_S3">
        <FORM>tjevuta lja a zua kiyaw</FORM>
        <AUDIO start="39.949" end="41.949"/>
    </S>
    <S id="Y2_frog_tji01n_S4">
        <FORM>ljakuli mavilavilad ljakua a mavilad anga</FORM>
        <AUDIO start="41.949" end="46.152"/>
    </S>
    <S id="Y2_frog_tji01n_S5">
        <FORM>pai ka kadjamadjaman, migacalj a za ti cingivengan katu za vatu</FORM>
        <AUDIO start="46.152" end="51.932"/>
    </S>
    <S id="Y2_frog_tji01n_S6">
        <FORM>pacunan a za vatjukun ay</FORM>
        <AUDIO start="51.932" end="54.034"/>
    </S>
    <S id="Y2_frog_tji01n_S7">
        <FORM>vaku neka anga azua</FORM>
        <AUDIO start="54.034" end="56.033"/>
    </S>
    <S id="Y2_frog_tji01n_S8">
        <FORM>ku kiaw na mavilad anga</FORM>
        <AUDIO start="56.033" end="58.253"/>
    </S>
    <S id="Y2_frog_tji01n_S9">
        <FORM>ayaya sa a ti cingivengan kata vatu nimadju</FORM>
        <AUDIO start="58.253" end="63.118"/>
    </S>
    <S id="Y2_frog_tji01n_S10">
        <FORM>pai patagiljen a karakim</FORM>
        <AUDIO start="63.118" end="66.101"/>
    </S>
    <S id="Y2_frog_tji01n_S11">
        <FORM>a karakim ta zua qaqelengan nimadju</FORM>
        <AUDIO start="66.203" end="70.22"/>
    </S>
    <S id="Y2_frog_tji01n_S12">
        <FORM>aicu a anema tu anema</FORM>
        <AUDIO start="70.22" end="72.254"/>
    </S>
    <S id="Y2_frog_tji01n_S13">
        <FORM>e vaiken a pacun a pasainu tu sainu ainu anga za ku kiaw</FORM>
        <AUDIO start="72.288" end="77.172"/>
    </S>
    <S id="Y2_frog_tji01n_S14">
        <FORM>ayaya kimikim</FORM>
        <AUDIO start="77.172" end="78.746"/>
    </S>
    <S id="Y2_frog_tji01n_S15">
        <FORM>sa a aicu a vatu nimadju tu i na kemuda</FORM>
        <AUDIO start="78.746" end="81.881"/>
    </S>
    <S id="Y2_frog_tji01n_S16">
        <FORM>aicu a qulu paljetaladjen ta za zua</FORM>
        <AUDIO start="81.881" end="84.966"/>
    </S>
    <S id="Y2_frog_tji01n_S17">
        <FORM>a vatjukun a sinipapu kiaw ta sauni</FORM>
        <AUDIO start="84.966" end="87.897"/>
    </S>
    <S id="Y2_frog_tji01n_S18">
        <FORM>sakasakev</FORM>
        <AUDIO start="87.897" end="89.067"/>
    </S>
    <S id="Y2_frog_tji01n_S19">
        <FORM>a zua qulu nimadju</FORM>
        <AUDIO start="89.067" end="91.253"/>
    </S>
</TEXT>
