<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_past_interactions_with_Kasavakan_pulj01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: past interactions with Kasavakan_pulj01 1 min.eaf; anonymized speaker label: pulj01" audio="past interactions with Kasavakan_pulj01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S1">
        <FORM>izua anan a za ku vuvu anga ti marekerek a za ku vuvu ti marekerek</FORM>
        <AUDIO start="1.75" end="6.042"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S2">
        <FORM>e a ta zua tima azua tjavuqel a vusam ta zua vusam amaya itjen mazangilj mazazangiljan</FORM>
        <AUDIO start="6.2" end="12.369"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S3">
        <FORM>qau izua anan su a ta zua a sicuayan anan</FORM>
        <AUDIO start="12.707" end="15.567"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S4">
        <FORM>a za izua anan niamen izua anan niamen valjaw izua a za valjaw</FORM>
        <AUDIO start="15.567" end="18.494"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S5">
        <FORM>imaza i i kasavakan kasavakan</FORM>
        <AUDIO start="18.494" end="21.376"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S6">
        <FORM>izua nu malikap tiamen izua aya</FORM>
        <AUDIO start="21.376" end="23.677"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S7">
        <FORM>izua nu kemacu ta mara a sizi aya mara vavuy aya</FORM>
        <AUDIO start="23.677" end="30.235"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S8">
        <FORM>umiyaki tja ayavaw lja</FORM>
        <AUDIO start="30.235" end="31.411"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S9">
        <FORM>qau kedri a ku kinacu semaza i kasavakan</FORM>
        <AUDIO start="31.411" end="35.153"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S10">
        <FORM>qau inia maqati a caucau a aya pai a a kemacu</FORM>
        <AUDIO start="35.153" end="39.384"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S11">
        <FORM>izua nu amin a gung e aya a a aya a cimu ta aicu a mara umiaki</FORM>
        <AUDIO start="39.384" end="47.026"/>
    </S>
    <S id="Y2_past_interactions_with_Kasavakan_pulj01_S12">
        <FORM>qau a za uri mangtjez anan a na matucu</FORM>
        <AUDIO start="47.026" end="49.372"/>
    </S>
</TEXT>
