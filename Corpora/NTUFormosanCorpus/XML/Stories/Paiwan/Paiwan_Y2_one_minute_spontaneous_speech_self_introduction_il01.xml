<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_self_introduction_il01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: self introduction_il01 1 min.eaf; anonymized speaker label: il01" audio="self introduction_il01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_self_introduction_il01_S1">
        <FORM>aku azua nu aya itjen</FORM>
        <AUDIO start="171.009" end="172.884"/>
    </S>
    <S id="Y2_self_introduction_il01_S2">
        <FORM>e ti vuvu e tiamadju kasi cuayan a tjala qavus</FORM>
        <AUDIO start="172.884" end="177.538"/>
    </S>
    <S id="Y2_self_introduction_il01_S3">
        <FORM>nana i tjulivar imaza i i tua i ka piuman.</FORM>
        <AUDIO start="177.538" end="182.362"/>
    </S>
    <S id="Y2_self_introduction_il01_S4">
        <FORM>sa kamar emarivu tiamadju.</FORM>
        <AUDIO start="182.363" end="185.438"/>
    </S>
    <S id="Y2_self_introduction_il01_S5">
        <FORM>tia vuvu e a na madju</FORM>
        <AUDIO start="185.438" end="187.475"/>
    </S>
    <S id="Y2_self_introduction_il01_S6">
        <FORM>na kiqadjuq a tjaljumaza i ka e ka piuman.</FORM>
        <AUDIO start="187.5" end="190.487"/>
    </S>
    <S id="Y2_self_introduction_il01_S7">
        <FORM>sa kitevelj anga tua se piuma.</FORM>
        <AUDIO start="190.488" end="192.825"/>
    </S>
    <S id="Y2_self_introduction_il01_S8">
        <FORM>manu</FORM>
        <AUDIO start="192.825" end="194.931"/>
    </S>
    <S id="Y2_self_introduction_il01_S9">
        <FORM>ti vuvu ta zua e ti vuvu i lamauwan ta zua</FORM>
        <AUDIO start="194.931" end="199.031"/>
    </S>
    <S id="Y2_self_introduction_il01_S10">
        <FORM>e ljatua timadju palisi</FORM>
        <AUDIO start="199.037" end="201.512"/>
    </S>
    <S id="Y2_self_introduction_il01_S11">
        <FORM>kararingen timadju imaza i qinaljan tua palisi.</FORM>
        <AUDIO start="201.512" end="205.2"/>
    </S>
    <S id="Y2_self_introduction_il01_S12">
        <FORM>e manu</FORM>
        <AUDIO start="205.2" end="206.364"/>
    </S>
    <S id="Y2_self_introduction_il01_S13">
        <FORM>tja cuacuay timadju imazamaza i</FORM>
        <AUDIO start="206.364" end="208.826"/>
    </S>
    <S id="Y2_self_introduction_il01_S14">
        <FORM>e sa ti lapan azua ti vuvu i ljamauwan.</FORM>
        <AUDIO start="208.826" end="212.066"/>
    </S>
    <S id="Y2_self_introduction_il01_S15">
        <FORM>e aku a za patje kai aken ta timadju nu aya itjen patje maca ti vuvu.</FORM>
        <AUDIO start="212.066" end="217.413"/>
    </S>
    <S id="Y2_self_introduction_il01_S16">
        <FORM>imaza i sadilapan sakamaya</FORM>
        <AUDIO start="217.413" end="220.423"/>
    </S>
    <S id="Y2_self_introduction_il01_S17">
        <FORM>patje tua e unem a puluq ta zua, e ini</FORM>
        <AUDIO start="220.423" end="225.365"/>
    </S>
    <S id="Y2_self_introduction_il01_S18">
        <FORM>e sepatj a puluq haka drusa cavilj ta zua patagilj anga a masalu imaza i qinaljan tua cemas.</FORM>
        <AUDIO start="225.375" end="231.903"/>
    </S>
</TEXT>
