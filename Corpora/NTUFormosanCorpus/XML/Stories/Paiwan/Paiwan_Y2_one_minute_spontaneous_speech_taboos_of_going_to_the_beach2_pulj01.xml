    <S id="Y2_taboos_of_going_to_the_beach2_pulj01_S1">
        <FORM>a ta zua qaqunuan amen</FORM>
        <AUDIO start="1.19" end="2.703"/>
    </S>
    <S id="Y2_taboos_of_going_to_the_beach2_pulj01_S2">
        <FORM>nu vaik amen a izi ljavek a kivangvang nu vaik amen i i ljavek a kivangvang tjala dikinay qivu ta za qarimarawmaraw aya</FORM>
        <AUDIO start="3.094" end="12.343"/>
    </S>
    <S id="Y2_taboos_of_going_to_the_beach2_pulj01_S3">
        <FORM>anema aya itjen nu qivu ta qarimarawmaraw palisi</FORM>
        <AUDIO start="12.509" end="14.509"/>
    </S>
    <S id="Y2_taboos_of_going_to_the_beach2_pulj01_S4">
        <FORM>anema palisi aya itjen</FORM>
        <AUDIO start="14.509" end="15.749"/>
    </S>
    <S id="Y2_taboos_of_going_to_the_beach2_pulj01_S5">
        <FORM>uri muqaca za ljavek</FORM>
