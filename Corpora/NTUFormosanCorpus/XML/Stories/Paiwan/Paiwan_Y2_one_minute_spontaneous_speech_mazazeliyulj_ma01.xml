<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_mazazeliyulj_ma01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: mazazeliyulj_ma01 1 min.eaf; anonymized speaker label: ma01" audio="mazazeliyulj_ma01.wav" dialect="Southern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_mazazeliyulj_ma01_S1">
        <FORM>neka anga azua mazazeliulj a tucu avan anga.</FORM>
        <AUDIO start="115.487" end="118.631"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S2">
        <FORM>e paisu tu pida li sipazeliulj tjanu itjen</FORM>
        <AUDIO start="118.631" end="121.92"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S3">
        <FORM>avan anga tja a pacucun a na tucu.</FORM>
        <AUDIO start="121.92" end="124.749"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S4">
        <FORM>lja a i qinaljan</FORM>
        <AUDIO start="124.749" end="126.447"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S5">
        <FORM>a tja a pacunan a na mare kiljivaljivak a maqaqeljeqeljing ta sengsengan.</FORM>
        <AUDIO start="126.447" end="130.776"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S6">
        <FORM>nu cecevung tjen a tja</FORM>
        <AUDIO start="130.776" end="132.605"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S7">
        <FORM>e siselapay</FORM>
        <AUDIO start="132.683" end="134.079"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S8">
        <FORM>a nu izua</FORM>
        <AUDIO start="134.079" end="135.131"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S9">
        <FORM>e vaivaik a kitjukuda tjanu itjen a tja sikataqalan.</FORM>
        <AUDIO start="135.17" end="138.525"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S10">
        <FORM>amin anga a mapacucun i qinaljan i ta</FORM>
        <AUDIO start="138.526" end="141.394"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S11">
        <FORM>i ta e ma paulaula</FORM>
        <AUDIO start="141.434" end="143.96"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S12">
        <FORM>i tua nu izua uri pucekelj i tjanu itjen i qinaljan a tja</FORM>
        <AUDIO start="143.96" end="147.487"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S13">
        <FORM>a sikataqalan a makacevucevung.</FORM>
        <AUDIO start="147.5" end="149.763"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S14">
        <FORM>avan anga tja pacun a na</FORM>
        <AUDIO start="149.763" end="151.789"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S15">
        <FORM>e mazazeliuliulj maqaqeljeqeljing itjen ta tja sengesengan.</FORM>
        <AUDIO start="151.789" end="155.565"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S16">
        <FORM>e vaik itjen a ljemaveljav.</FORM>
        <AUDIO start="155.565" end="157.381"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S17">
        <FORM>a vaik itjen a pusaladj a na kemacu ta</FORM>
        <AUDIO start="157.381" end="160.131"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S18">
        <FORM>a tjukur a ma ta</FORM>
        <AUDIO start="160.144" end="161.829"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S19">
        <FORM>a na mapaula i tjanu itjen i qinaljan</FORM>
        <AUDIO start="161.881" end="164.565"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S20">
        <FORM>katua nu izua uri pucekelj.</FORM>
        <AUDIO start="164.658" end="167.407"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S21">
        <FORM>e maraurau itjen a vaik a ma ta cemekeljan pusaladj ta sengsengan</FORM>
        <AUDIO start="167.407" end="172.117"/>
    </S>
    <S id="Y2_mazazeliyulj_ma01_S22">
        <FORM>a pusaladj ta e anema anga malinu.</FORM>
        <AUDIO start="172.131" end="175.776"/>
    </S>
</TEXT>
