<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_pear_ma01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: pear_ma01 1 min.eaf; anonymized speaker label: ma01" audio="pear_ma01.wav" dialect="Southern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_pear_ma01_S1">
        <FORM>cemalivat a matjelu a mareqaliqalian a uqaljaqaljay</FORM>
        <AUDIO start="86.412" end="91.725"/>
    </S>
    <S id="Y2_pear_ma01_S2">
        <FORM>pusaladjan timadju a lemulju ta azua a ljavac.</FORM>
        <AUDIO start="91.725" end="95.489"/>
    </S>
    <S id="Y2_pear_ma01_S3">
        <FORM>sa e kiaki a sidingsia</FORM>
        <AUDIO start="95.489" end="98.47"/>
    </S>
    <S id="Y2_pear_ma01_S4">
        <FORM>sa pusaladji a paljevavaw azua i ta pulu a lavac.</FORM>
        <AUDIO start="98.49" end="103.49"/>
    </S>
    <S id="Y2_pear_ma01_S5">
        <FORM>ka vaivaik anga azua ti e uqaljay a maka sidingsia</FORM>
        <AUDIO start="103.529" end="108.333"/>
    </S>
    <S id="Y2_pear_ma01_S6">
        <FORM>azua a matjelu a uqaljaqaljay.</FORM>
        <AUDIO start="108.333" end="110.667"/>
    </S>
    <S id="Y2_pear_ma01_S7">
        <FORM>e pacun a na e tjalupung azua uqaljay a na matjani.</FORM>
        <AUDIO start="110.667" end="114.94"/>
    </S>
    <S id="Y2_pear_ma01_S8">
        <FORM>manu ljuljuin nimadju</FORM>
        <AUDIO start="114.94" end="117"/>
    </S>
    <S id="Y2_pear_ma01_S9">
        <FORM>e sa pacun a pasalikuz.</FORM>
        <AUDIO start="117" end="119.529"/>
    </S>
    <S id="Y2_pear_ma01_S10">
        <FORM>manu e paljuk azua na ljemulu tjalupung a uqaljay</FORM>
        <AUDIO start="119.529" end="124.45"/>
    </S>
    <S id="Y2_pear_ma01_S11">
        <FORM>sa laingi azua</FORM>
        <AUDIO start="124.45" end="126.117"/>
    </S>
    <S id="Y2_pear_ma01_S12">
        <FORM>makasidingsiasia a uqaljay sa pavayan a tjalupung nimadju.</FORM>
        <AUDIO start="126.137" end="129.94"/>
    </S>
    <S id="Y2_pear_ma01_S13">
        <FORM>e azua a makasidingsiasia a uqaljay</FORM>
        <AUDIO start="129.94" end="132.568"/>
    </S>
    <S id="Y2_pear_ma01_S14">
        <FORM>e na masalu na kemasilevan timadju.</FORM>
        <AUDIO start="132.568" end="135.803"/>
    </S>
    <S id="Y2_pear_ma01_S15">
        <FORM>sa pavayan azua na ljemulju tjalupung nimadju uqaljay tu tjelu ta ljavac.</FORM>
        <AUDIO start="135.803" end="141.255"/>
    </S>
    <S id="Y2_pear_ma01_S16">
        <FORM>e sipumasalu nimadju.</FORM>
        <AUDIO start="141.255" end="144.038"/>
    </S>
    <S id="Y2_pear_ma01_S17">
        <FORM>e azua namarap ta tjelu a ljavac</FORM>
        <AUDIO start="144.038" end="147.136"/>
    </S>
    <S id="Y2_pear_ma01_S18">
        <FORM>siqaruqaurut ta salasaladj nimadju.</FORM>
        <AUDIO start="147.156" end="150.176"/>
    </S>
</TEXT>
