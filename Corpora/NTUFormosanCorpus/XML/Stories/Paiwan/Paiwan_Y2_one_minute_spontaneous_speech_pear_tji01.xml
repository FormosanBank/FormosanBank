<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_pear_tji01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: pear_tji01 1 min.eaf; anonymized speaker label: tji01" audio="pear_tji01.wav" dialect="Central Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_pear_tji01_S1">
        <FORM>a se pucekalu ta zua qaciljay</FORM>
        <AUDIO start="113.55" end="116.4"/>
    </S>
    <S id="Y2_pear_tji01_S2">
        <FORM>sa kaipuk</FORM>
        <AUDIO start="116.44" end="117.68"/>
    </S>
    <S id="Y2_pear_tji01_S3">
        <FORM>sa</FORM>
        <AUDIO start="117.68" end="118.78"/>
    </S>
    <S id="Y2_pear_tji01_S4">
        <FORM>matjani azua kini na va ni kama a i ta dra drakuyan.</FORM>
        <AUDIO start="118.78" end="123.41"/>
    </S>
    <S id="Y2_pear_tji01_S5">
        <FORM>pai sa e migacalj a za ti e uqaljay.</FORM>
        <AUDIO start="123.41" end="127.25"/>
    </S>
    <S id="Y2_pear_tji01_S6">
        <FORM>sa uri ljuljuin manu izua za</FORM>
        <AUDIO start="127.25" end="129.99"/>
    </S>
    <S id="Y2_pear_tji01_S7">
        <FORM>a cemalivalivat</FORM>
        <AUDIO start="129.99" end="132.35"/>
    </S>
    <S id="Y2_pear_tji01_S8">
        <FORM>a matjelu, a madrusa a uqaljay a macidilj a vavayan.</FORM>
        <AUDIO start="132.35" end="137.08"/>
    </S>
    <S id="Y2_pear_tji01_S9">
        <FORM>sa pusaladji</FORM>
        <AUDIO start="137.08" end="138.53"/>
    </S>
    <S id="Y2_pear_tji01_S10">
        <FORM>a ljemulu tucu a</FORM>
        <AUDIO start="138.54" end="140.55"/>
    </S>
    <S id="Y2_pear_tji01_S11">
        <FORM>a navac a pasazua i ta</FORM>
        <AUDIO start="140.55" end="143.24"/>
    </S>
    <S id="Y2_pear_tji01_S12">
        <FORM>e vatju ta zua dradrakuyan ku ayavaw.</FORM>
        <AUDIO start="143.24" end="146.87"/>
    </S>
    <S id="Y2_pear_tji01_S13">
        <FORM>sa aicu a ti uqaljay a kakedrian kasaluan a zua ma</FORM>
        <AUDIO start="146.87" end="150.84"/>
    </S>
    <S id="Y2_pear_tji01_S14">
        <FORM>matjelu masalu kimayanaya.</FORM>
        <AUDIO start="150.84" end="153.25"/>
    </S>
    <S id="Y2_pear_tji01_S15">
        <FORM>sa e ui pinaka anga, uri vaivavik anga.</FORM>
        <AUDIO start="153.25" end="157.58"/>
    </S>
    <S id="Y2_pear_tji01_S16">
        <FORM>sa manu</FORM>
        <AUDIO start="157.58" end="158.62"/>
    </S>
    <S id="Y2_pear_tji01_S17">
        <FORM>djauljen na zua matjelu a uqaljay.</FORM>
        <AUDIO start="158.62" end="161.36"/>
    </S>
    <S id="Y2_pear_tji01_S18">
        <FORM>qalian avan za su tjalupung.</FORM>
        <AUDIO start="161.36" end="164.06"/>
    </S>
    <S id="Y2_pear_tji01_S19">
        <FORM>su inadju anga u za ayain anga.</FORM>
        <AUDIO start="164.06" end="167.01"/>
    </S>
    <S id="Y2_pear_tji01_S20">
        <FORM>sa ui</FORM>
        <AUDIO start="167.01" end="168.28"/>
    </S>
    <S id="Y2_pear_tji01_S21">
        <FORM>e kasaluan a za uqaljay sa</FORM>
        <AUDIO start="168.28" end="171.06"/>
    </S>
    <S id="Y2_pear_tji01_S22">
        <FORM>a paljavakan</FORM>
        <AUDIO start="171.06" end="172.41"/>
    </S>
    <S id="Y2_pear_tji01_S23">
        <FORM>ta zua tjelu a navac, a za tiamadju matjelu.</FORM>
        <AUDIO start="172.41" end="176.14"/>
    </S>
    <S id="Y2_pear_tji01_S24">
        <FORM>a tiamadju</FORM>
        <AUDIO start="176.16" end="177.48"/>
    </S>
    <S id="Y2_pear_tji01_S25">
        <FORM>a sapare pavayan tucu a navac.</FORM>
        <AUDIO start="177.48" end="180.36"/>
    </S>
</TEXT>
