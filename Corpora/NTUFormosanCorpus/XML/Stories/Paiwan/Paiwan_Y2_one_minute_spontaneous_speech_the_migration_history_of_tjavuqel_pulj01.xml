<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_the_migration_history_of_tjavuqel_pulj01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: the migration history of tjavuqel_pulj01 1 min.eaf; anonymized speaker label: pulj01" audio="the migration history of tjavuqel_pulj01.wav" dialect="Northern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S1">
        <FORM>manu izua a za saqetjuan aya.</FORM>
        <AUDIO start="60.762" end="62.641"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S2">
        <FORM>manu patjavan tiamadju sema izua i i aya i qareqepunan, qareqepunan.</FORM>
        <AUDIO start="62.645" end="68.118"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S3">
        <FORM>a manu tu kemuda aya tauta qadjaw temalem ta nemanga ini a maqati aya.</FORM>
        <AUDIO start="68.26" end="73.73"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S4">
        <FORM>qau tjizaya pasazui i tjavuqel.</FORM>
        <AUDIO start="74.14" end="77.08"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S5">
        <FORM>qau aicu a tjavuqel, avan azua tucu i katjavuqelan katjavuqelan.</FORM>
        <AUDIO start="77.104" end="81.81"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S6">
        <FORM>qau ka cacacuayan anga sema zua aya manu manu a za niamen a mazazangiljan a za ngadan ti mamag aya, ti mamag.</FORM>
        <AUDIO start="81.97" end="91.15"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S7">
        <FORM>a zua ti mamag, manu puvaljaw ta sepudur.</FORM>
        <AUDIO start="91.28" end="94.742"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S8">
        <FORM>sepu ta sepudur e vaik pu puvaljaw ta sepudur.</FORM>
        <AUDIO start="95.427" end="100.029"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S9">
        <FORM>e tu kemuda aya kacuin a sepudur a sema tja i i tjavuqel.</FORM>
        <AUDIO start="100.359" end="105.675"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S10">
        <FORM>akumaya pungadan a tjavuqel aya.</FORM>
        <AUDIO start="106.047" end="108.276"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S11">
        <FORM>qau a ta zua i a za tiamen i sepudur semazui katjavuqelan.</FORM>
        <AUDIO start="108.514" end="113.592"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S12">
        <FORM>e ui a ama aya itjen ta zua uri temapaw aya itjen a seman umaq.</FORM>
        <AUDIO start="113.958" end="118.347"/>
    </S>
    <S id="Y2_the_migration_history_of_tjavuqel_pulj01_S13">
        <FORM>aya seman umaq tiamadju.</FORM>
        <AUDIO start="118.712" end="120.178"/>
    </S>
</TEXT>
