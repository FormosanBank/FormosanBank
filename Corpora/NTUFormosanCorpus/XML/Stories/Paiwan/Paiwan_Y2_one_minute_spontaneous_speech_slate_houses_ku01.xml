<?xml version="1.0" ?>
<TEXT id="NTU_Stry_Paiwan_Y2_one_minute_spontaneous_speech_slate_houses_ku01" xml:lang="pwn" source="NTU Corpus, Paiwan, Y2 one-minute spontaneous speech; source EAF: slate houses_ku01 1 min.eaf; anonymized speaker label: ku01" audio="slate houses_ku01.wav" dialect="Eastern Paiwan" copyright="" citation="" BibTeX_citation="">
    <S id="Y2_slate_houses_ku01_S1">
        <FORM>qau, azua a ramaljeng ka</FORM>
        <AUDIO start="90.039" end="92.249"/>
    </S>
    <S id="Y2_slate_houses_ku01_S2">
        <FORM>lemangda ta zua kai na zua vulung, tapuluin.</FORM>
        <AUDIO start="92.249" end="96.012"/>
    </S>
    <S id="Y2_slate_houses_ku01_S3">
        <FORM>qau, a za ramaljeng ka ta tapuluin, mintjus ti a za ramaljeng.</FORM>
        <AUDIO start="96.012" end="100.434"/>
    </S>
    <S id="Y2_slate_houses_ku01_S4">
        <FORM>ia, cua qaljic na qatjuvi.</FORM>
        <AUDIO start="100.434" end="102.592"/>
    </S>
    <S id="Y2_slate_houses_ku01_S5">
        <FORM>madu a zua i pana i gadu a za a qaciljay aya.</FORM>
        <AUDIO start="102.592" end="107.605"/>
    </S>
    <S id="Y2_slate_houses_ku01_S6">
        <FORM>qau, ka vi tjaivililj anga,</FORM>
        <AUDIO start="107.605" end="110.671"/>
    </S>
    <S id="Y2_slate_houses_ku01_S7">
        <FORM>e rasudjen sa qapui a mareka a maqacuvucuvung aza a</FORM>
        <AUDIO start="110.671" end="115.473"/>
    </S>
    <S id="Y2_slate_houses_ku01_S8">
        <FORM>a sikataqaljan</FORM>
        <AUDIO start="115.473" end="117.842"/>
    </S>
    <S id="Y2_slate_houses_ku01_S9">
        <FORM>vaik a ma pana, semakuc ta ka ta qaciljay.</FORM>
        <AUDIO start="117.842" end="121.013"/>
    </S>
    <S id="Y2_slate_houses_ku01_S10">
        <FORM>vaik a sema ga gadu a, marap ta qaciljay.</FORM>
        <AUDIO start="121.013" end="123.841"/>
    </S>
    <S id="Y2_slate_houses_ku01_S11">
        <FORM>sa kipacuali ta zua na</FORM>
        <AUDIO start="123.841" end="126.289"/>
    </S>
    <S id="Y2_slate_houses_ku01_S12">
        <FORM>vulung a qaljic a</FORM>
        <AUDIO start="126.289" end="128.157"/>
    </S>
    <S id="Y2_slate_houses_ku01_S13">
        <FORM>sa djumulji a mayatucu a pasa vavaw.</FORM>
        <AUDIO start="128.158" end="130.974"/>
    </S>
    <S id="Y2_slate_houses_ku01_S14">
        <FORM>ka cuay anga, masan masan tucu anga a qaciljay</FORM>
        <AUDIO start="130.974" end="135.026"/>
    </S>
    <S id="Y2_slate_houses_ku01_S15">
        <FORM>qaciljay a i sinan umaq.</FORM>
        <AUDIO start="135.026" end="137.684"/>
    </S>
    <S id="Y2_slate_houses_ku01_S16">
        <FORM>ma tucu a tucu anga</FORM>
        <AUDIO start="137.684" end="139.526"/>
    </S>
    <S id="Y2_slate_houses_ku01_S17">
        <FORM>patjave timitja a tjaiviljiviljilj a sevalivavid.</FORM>
        <AUDIO start="139.526" end="142.645"/>
    </S>
    <S id="Y2_slate_houses_ku01_S18">
        <FORM>akumaya tja sini pinakaljayan a</FORM>
        <AUDIO start="142.645" end="146.052"/>
    </S>
    <S id="Y2_slate_houses_ku01_S19">
        <FORM>a vulung nu aya itjen, ulja na maitucu timadju a na pavay tjanu itjen tja</FORM>
        <AUDIO start="146.052" end="150.394"/>
    </S>
    <S id="Y2_slate_houses_ku01_S20">
        <FORM>puqenetjan.</FORM>
        <AUDIO start="150.394" end="151.657"/>
    </S>
</TEXT>
