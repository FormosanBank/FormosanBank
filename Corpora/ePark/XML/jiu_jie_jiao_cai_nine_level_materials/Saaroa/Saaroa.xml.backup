    <S id="351">
        <FORM kindOf="original">karʉkʉhlʉaku tuapuru kalahlapa kiu'u tumimahla tamu'u kisuahlahlama.</FORM>
        <PHON kindOf="original">karɨkɨɬɨaku tuapuru kaɾaɬapa kiuʔu tumimaɬa tamuʔu kisuaɬaɬama.</PHON>
        <FORM kindOf="standard">karʉkʉhlʉaku tuapuru kalahlapa kiu'u tumimahla tamu'u kisuahlahlama.</FORM>
