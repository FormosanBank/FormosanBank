    </S>
    <S id="213877">
        <FORM kindOf="original">Foi's i kakarayan,</FORM>
        <PHON kindOf="original">fo~uiʡs i kakarajan,</PHON>
        <FORM kindOf="standard">Foi's i kakarayan,</FORM>
        <PHON kindOf="standard">fo~uiʡs i kakarajan,</PHON>
        <TRANSL xml:lang="zho">天上的星星，</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213877.wav" url="https://web.klokah.tw/text/sound//17254/213877.mp3" start="0" end="2.66"/>
    </S>
    <S id="213878">
        <FORM kindOf="original">Samiyatmiyat sa masedi.</FORM>
        <PHON kindOf="original">samijatmijat sa masəɬi.</PHON>
        <FORM kindOf="standard">Samiyatmiyat sa masedi.</FORM>
        <PHON kindOf="standard">samijatmijat sa masəɬi.</PHON>
        <TRANSL xml:lang="zho">閃閃好似在微笑。</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213878.wav" url="https://web.klokah.tw/text/sound//17254/213878.mp3" start="0" end="3.5"/>
    </S>
    <S id="213879">
        <FORM kindOf="original">Malahedaw ko 'orad,</FORM>
        <PHON kindOf="original">maɾaħəɬaw ko~u ʡo~uraɬ,</PHON>
        <FORM kindOf="standard">Malahedaw ko 'orad,</FORM>
        <PHON kindOf="standard">maɾaħəɬaw ko~u ʡo~uraɬ,</PHON>
        <TRANSL xml:lang="zho">雨兒不見了，</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213879.wav" url="https://web.klokah.tw/text/sound//17255/213879.mp3" start="0" end="2.69"/>
    </S>
    <S id="213880">
        <FORM kindOf="original">Sadak sa ko talakar ni Idek,</FORM>
        <PHON kindOf="original">saɬak sa ko~u taɾakar ni iɬək,</PHON>
        <FORM kindOf="standard">Sadak sa ko talakar ni Idek,</FORM>
        <PHON kindOf="standard">saɬak sa ko~u taɾakar ni iɬək,</PHON>
        <TRANSL xml:lang="zho">彩虹出現了，</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213880.wav" url="https://web.klokah.tw/text/sound//17255/213880.mp3" start="0" end="3.81"/>
    </S>
    <S id="213881">
        <FORM kindOf="original">Kahengangay, koheraay, kangdaway,</FORM>
        <PHON kindOf="original">kaħəŋaŋaj, ko~uħəraaj, kaŋɬawaj,</PHON>
        <FORM kindOf="standard">Kahengangay, koheraay, kangdaway,</FORM>
        <PHON kindOf="standard">kaħəŋaŋaj, ko~uħəraaj, kaŋɬawaj,</PHON>
        <TRANSL xml:lang="zho">紅的、黃的、綠的，</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213881.wav" url="https://web.klokah.tw/text/sound//17255/213881.mp3" start="0" end="5.83"/>
    </S>
    <S id="213882">
        <FORM kindOf="original">Talakar ni Idek tadamakapah.</FORM>
        <PHON kindOf="original">taɾakar ni iɬək taɬamakapaħ.</PHON>
        <FORM kindOf="standard">Talakar ni Idek tadamakapah.</FORM>
        <PHON kindOf="standard">taɾakar ni iɬək taɬamakapaħ.</PHON>
        <TRANSL xml:lang="zho">彩虹真的好漂亮。</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213882.wav" url="https://web.klokah.tw/text/sound//17255/213882.mp3" start="0" end="4.65"/>
    </S>
    <S id="213883">
        <FORM kindOf="original">Maolah si alofo ko fofo ato mamo,</FORM>
        <PHON kindOf="original">mao~uɾaħ si aɾo~ufo~u ko~u fo~ufo~u ato~u mamo~u,</PHON>
        <FORM kindOf="standard">Maolah si alofo ko fofo ato mamo,</FORM>
        <PHON kindOf="standard">mao~uɾaħ si aɾo~ufo~u ko~u fo~ufo~u ato~u mamo~u,</PHON>
        <TRANSL xml:lang="zho">爺爺奶奶喜歡穿戴揹袋，</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213883.wav" url="https://web.klokah.tw/text/sound//17256/213883.mp3" start="0" end="4.68"/>
    </S>
    <S id="213884">
        <FORM kindOf="original">Ay yay yay~ makapahay alofo,</FORM>
        <PHON kindOf="original">aj jaj jaj~ makapaħaj aɾo~ufo~u,</PHON>
        <FORM kindOf="standard">Ay yay yay~ makapahay alofo,</FORM>
        <PHON kindOf="standard">aj jaj jaj~ makapaħaj aɾo~ufo~u,</PHON>
        <TRANSL xml:lang="zho">哎呀呀! 好漂亮的揹袋，</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213884.wav" url="https://web.klokah.tw/text/sound//17256/213884.mp3" start="0" end="4.02"/>
    </S>
    <S id="213885">
        <FORM kindOf="original">Pasoso' sa to kamay i alofo,</FORM>
        <PHON kindOf="original">paso~uso~uʡ sa to~u kamaj i aɾo~ufo~u,</PHON>
        <FORM kindOf="standard">Pasoso' sa to kamay i alofo,</FORM>
        <PHON kindOf="standard">paso~uso~uʡ sa to~u kamaj i aɾo~ufo~u,</PHON>
        <TRANSL xml:lang="zho">手伸進揹袋裡，</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213885.wav" url="https://web.klokah.tw/text/sound//17256/213885.mp3" start="0" end="4.0"/>
    </S>
    <S id="213886">
        <FORM kindOf="original">Ilato i kamay ni fofo aci mamo ko icep.</FORM>
        <PHON kindOf="original">iɾato~u i kamaj ni fo~ufo~u aʦi mamo~u ko~u iʦəp.</PHON>
        <FORM kindOf="standard">Ilato i kamay ni fofo aci mamo ko icep.</FORM>
        <PHON kindOf="standard">iɾato~u i kamaj ni fo~ufo~u aʦi mamo~u ko~u iʦəp.</PHON>
        <TRANSL xml:lang="zho">檳榔就出現在爺爺奶奶的手裡。</TRANSL>
        <AUDIO file="tu_hua_gu_shi_pian_picture_story_Malan_Amis_213886.wav" url="https://web.klokah.tw/text/sound//17256/213886.mp3" start="0" end="7.5"/>
    </S>
