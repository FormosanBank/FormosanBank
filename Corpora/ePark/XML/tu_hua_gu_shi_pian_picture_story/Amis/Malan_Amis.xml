        <PHON kindOf="original">iɾa ko~u maapo~uħaj,</PHON>
        <FORM kindOf="standard">Ila ko maapohay,</FORM>
        <PHON kindOf="standard">iɾa ko~u maapo~uħaj,</PHON>
        <TRANSL xml:lang="zho">有的好朦朧，</TRANSL>
