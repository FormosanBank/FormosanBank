    <S id="019S1">
        <FORM kindOf="original">ka sitsuayan kinatsu a kemasi Pinavavuqatsang aza zua milingan.</FORM>
        <PHON kindOf="original">ka siʦuajan kinaʦu a kəmasi pinavavuqaʦaŋ aza zua miɭiŋan.</PHON>
        <FORM kindOf="standard">ka sicuayan kinacu a kemasi Pinavavuqacang aza zua milingan.</FORM>
        <PHON kindOf="standard">ka siʦuajan kinaʦu a kəmasi pinavavuqaʦaŋ aza zua miɣiŋan.</PHON>
