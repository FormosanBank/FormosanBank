    <S id="030S1">
        <FORM kindOf="original">ka sitsuayan neka pumuqan, neka ngilu, neka sengsengan; sa masepeɫ itjen.</FORM>
        <PHON kindOf="original">ka siʦuajan nəka pumuqan, nəka ŋiɭu, nəka səŋsəŋan; sa masəpəʎ icən.</PHON>
        <FORM kindOf="standard">ka sicuayan neka pumuqan, neka ngilu, neka sengsengan; sa masepelj itjen.</FORM>
        <PHON kindOf="standard">ka siʦuajan nəka pumuqan, nəka ŋiɣu, nəka səŋsəŋan; sa masəpəʎ iʦən.</PHON>
